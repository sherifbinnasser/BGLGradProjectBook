    \PYG{k}{if} \PYG{n}{best\PYGZus{}signal} \PYG{o+ow}{is} \PYG{k+kc}{None}\PYG{p}{:}
        \PYG{n}{best\PYGZus{}signal} \PYG{o}{=} \PYG{n}{components}\PYG{p}{[:,} \PYG{l+m+mi}{0}\PYG{p}{]}

    \PYG{k}{return} \PYG{n}{best\PYGZus{}signal}


