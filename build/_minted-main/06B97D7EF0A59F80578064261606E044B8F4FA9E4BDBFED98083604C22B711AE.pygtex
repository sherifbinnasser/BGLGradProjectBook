\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{\PYGZus{}read\PYGZus{}csv}\PYG{p}{(}\PYG{n}{file}\PYG{p}{:} \PYG{n}{UploadFile}\PYG{p}{):}
