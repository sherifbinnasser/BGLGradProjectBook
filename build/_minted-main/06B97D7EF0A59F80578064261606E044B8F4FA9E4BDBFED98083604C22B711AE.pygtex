        \PYG{k}{return} \PYG{n}{interpolator}\PYG{p}{(}\PYG{n}{x\PYGZus{}new}\PYG{p}{)}
    \PYG{k}{else}\PYG{p}{:}
        \PYG{k}{return} \PYG{n}{resample}\PYG{p}{(}\PYG{n}{signal}\PYG{p}{,} \PYG{n}{target\PYGZus{}len}\PYG{p}{)}


\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{preprocess}\PYG{p}{(}\PYG{n}{df}\PYG{p}{):}
