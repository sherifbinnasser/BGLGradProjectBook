\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{extract\PYGZus{}pca\PYGZus{}signal}\PYG{p}{(}\PYG{n}{rgb}\PYG{p}{,} \PYG{n}{fs}\PYG{p}{):}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Extract PPG signal using PCA + select best component.\PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{rgb} \PYG{o}{=} \PYG{n}{rgb}\PYG{o}{.}\PYG{n}{astype}\PYG{p}{(}\PYG{n}{np}\PYG{o}{.}\PYG{n}{float32}\PYG{p}{)}
    \PYG{n}{rgb} \PYG{o}{=} \PYG{p}{(}\PYG{n}{rgb} \PYG{o}{\PYGZhy{}} \PYG{n}{np}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{(}\PYG{n}{rgb}\PYG{p}{,} \PYG{n}{axis}\PYG{o}{=}\PYG{l+m+mi}{0}\PYG{p}{))} \PYG{o}{/} \PYG{p}{(}\PYG{n}{np}\PYG{o}{.}\PYG{n}{std}\PYG{p}{(}\PYG{n}{rgb}\PYG{p}{,} \PYG{n}{axis}\PYG{o}{=}\PYG{l+m+mi}{0}\PYG{p}{)} \PYG{o}{+} \PYG{l+m+mf}{1e\PYGZhy{}8}\PYG{p}{)}

    \PYG{n}{pca} \PYG{o}{=} \PYG{n}{PCA}\PYG{p}{(}\PYG{n}{n\PYGZus{}components}\PYG{o}{=}\PYG{l+m+mi}{3}\PYG{p}{)}
    \PYG{n}{components} \PYG{o}{=} \PYG{n}{pca}\PYG{o}{.}\PYG{n}{fit\PYGZus{}transform}\PYG{p}{(}\PYG{n}{rgb}\PYG{p}{)}

    \PYG{n}{best\PYGZus{}signal} \PYG{o}{=} \PYG{k+kc}{None}
    \PYG{n}{best\PYGZus{}score} \PYG{o}{=} \PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}

    \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{l+m+mi}{2}\PYG{p}{):}
        \PYG{n}{sig} \PYG{o}{=} \PYG{n}{components}\PYG{p}{[:,} \PYG{n}{i}\PYG{p}{]}
        \PYG{k}{try}\PYG{p}{:}
            \PYG{n}{sig\PYGZus{}f} \PYG{o}{=} \PYG{n}{bandpass\PYGZus{}filter}\PYG{p}{(}\PYG{n}{sig}\PYG{p}{,} \PYG{n}{fs}\PYG{p}{)}
            \PYG{n}{score} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{std}\PYG{p}{(}\PYG{n}{sig\PYGZus{}f}\PYG{p}{)}
